{
  "name": "usewebmcp",
  "version": "2.2.0",
  "description": "Standalone React hooks for strict core WebMCP tool registration with navigator.modelContext",
  "keywords": [
    "ai",
    "assistant",
    "browser",
    "hooks",
    "mcp",
    "model-context-protocol",
    "react",
    "react-hooks",
    "tools",
    "usewebmcp"
  ],
  "homepage": "https://github.com/WebMCP-org/npm-packages#readme",
  "bugs": {
    "url": "https://github.com/WebMCP-org/npm-packages/issues"
  },
  "license": "MIT",
  "author": "WebMCP Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WebMCP-org/npm-packages.git",
    "directory": "packages/usewebmcp"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vp pack",
    "build:prod": "NODE_ENV=prod vp pack",
    "check": "vp check --fix",
    "clean": "rm -rf dist",
    "format": "vp fmt --write",
    "lint": "vp lint --fix",
    "prepublishOnly": "pnpm run build:prod",
    "publish:dry": "pnpm publish --access public --dry-run",
    "publish:npm": "pnpm publish --access public",
    "test": "vp test run",
    "test:watch": "vp test",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.strict-null-checks-false.json --noEmit && vp test run --typecheck --silent"
  },
  "dependencies": {
    "@mcp-b/webmcp-polyfill": "workspace:*",
    "@mcp-b/webmcp-types": "workspace:*"
  },
  "devDependencies": {
    "@mcp-b/global": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "playwright": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-react": "^2.0.4"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  }
}
