{
  "name": "@mcp-b/webmcp-local-relay",
  "version": "2.3.2",
  "description": "Local MCP relay for browser WebMCP tools via embed iframe and localhost WebSocket",
  "keywords": [
    "ai-agents",
    "iframe",
    "localhost",
    "mcp",
    "model-context-protocol",
    "relay",
    "stdio",
    "webmcp"
  ],
  "homepage": "https://github.com/WebMCP-org/npm-packages#readme",
  "bugs": {
    "url": "https://github.com/WebMCP-org/npm-packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WebMCP-org/npm-packages.git",
    "directory": "packages/webmcp-local-relay"
  },
  "license": "MIT",
  "author": "Alex Nahas",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "webmcp-local-relay": "./dist/cli.mjs"
  },
  "files": [
    ".claude-plugin",
    ".mcp.json",
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "vp pack && node scripts/build-widget-html.js",
    "build:mcpb": "bash scripts/build-mcpb.sh",
    "check": "vp check --fix",
    "clean": "rm -rf dist",
    "format": "vp fmt --write",
    "lint": "vp lint --fix",
    "prepublishOnly": "node ../../scripts/validate-publish.js && pnpm run build",
    "test": "vp test run",
    "test:e2e": "pnpm --filter @mcp-b/webmcp-polyfill build && pnpm --filter @mcp-b/global build && pnpm run build && vp test run --config vitest.e2e.config.ts",
    "test:watch": "vp test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.browser.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "ws": "^8.18.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@mcp-b/webmcp-types": "workspace:*",
    "@types/node": "catalog:",
    "@types/ws": "^8.5.14",
    "@vitest/coverage-v8": "catalog:",
    "msw": "2.12.10",
    "playwright": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
