{
  "name": "@mcp-b/webmcp-ts-sdk",
  "version": "2.2.0",
  "description": "Browser-adapted MCP TypeScript SDK - Dynamic tool registration for W3C Web Model Context API and AI agent integration",
  "keywords": [
    "adapter",
    "ai-agents",
    "ai-integration",
    "anthropic",
    "browser",
    "chatgpt",
    "claude",
    "copilot",
    "cursor",
    "dynamic-tools",
    "gemini",
    "llm",
    "mcp",
    "mcp-client",
    "mcp-server",
    "model-context-protocol",
    "navigator-modelcontext",
    "openai",
    "sdk",
    "tool-registration",
    "typescript",
    "w3c",
    "web-model-context",
    "webmcp"
  ],
  "homepage": "https://docs.mcp-b.ai/packages/webmcp-ts-sdk",
  "bugs": {
    "url": "https://github.com/WebMCP-org/npm-packages/issues"
  },
  "license": "MIT",
  "author": "Alex Nahas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WebMCP-org/npm-packages.git",
    "directory": "packages/webmcp-ts-sdk"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp check --fix",
    "clean": "rm -rf dist",
    "format": "vp fmt --write",
    "lint": "vp lint --fix",
    "prepublishOnly": "node ../../scripts/validate-publish.js && pnpm run build",
    "publish:dry": "pnpm publish --access public --dry-run",
    "publish:npm": "pnpm publish --access public",
    "typecheck": "tsc --noEmit",
    "version:major": "pnpm version major --no-git-tag-version",
    "version:minor": "pnpm version minor --no-git-tag-version",
    "version:patch": "pnpm version patch --no-git-tag-version"
  },
  "dependencies": {
    "@mcp-b/webmcp-polyfill": "workspace:*",
    "@mcp-b/webmcp-types": "workspace:*"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "zod": "^3.25 || ^4.0",
    "zod-to-json-schema": "^3.25.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "zod-to-json-schema": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
