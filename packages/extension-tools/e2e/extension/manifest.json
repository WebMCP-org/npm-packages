{
  "manifest_version": 3,
  "name": "Extension Runtime Contract",
  "version": "1.0.0",
  "minimum_chrome_version": "120",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "cookies",
    "downloads",
    "permissions",
    "scripting",
    "tabs",
    "userScripts"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Runtime Contract"
  }
}
