{
  "name": "@mcp-b/codemode",
  "version": "0.0.1",
  "description": "Browser-native code sandbox for LLM-generated tool orchestration",
  "keywords": [
    "ai",
    "codemode",
    "iframe",
    "isolation",
    "llm",
    "mcp",
    "sandbox",
    "tool-calling",
    "webmcp"
  ],
  "homepage": "https://docs.mcp-b.ai/packages/codemode",
  "bugs": {
    "url": "https://github.com/WebMCP-org/npm-packages/issues"
  },
  "license": "MIT",
  "author": "Alex Nahas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WebMCP-org/npm-packages.git",
    "directory": "packages/codemode"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./webmcp": {
      "types": "./dist/webmcp.d.ts",
      "import": "./dist/webmcp.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp check --fix",
    "clean": "rm -rf dist",
    "format": "vp fmt --write",
    "lint": "vp lint --fix",
    "prepublishOnly": "node ../../scripts/validate-publish.js && pnpm run build",
    "publish:dry": "pnpm publish --access public --dry-run",
    "publish:npm": "pnpm publish --access public",
    "test": "vp test run",
    "test:watch": "vp test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/json-schema": "^7.0.15",
    "acorn": "^8.16.0"
  },
  "devDependencies": {
    "ai": "catalog:",
    "msw": "^2.12.10",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@mcp-b/webmcp-types": "workspace:*",
    "ai": "^5.0.0",
    "zod": "^3.25 || ^4.0"
  },
  "peerDependenciesMeta": {
    "@mcp-b/webmcp-types": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
