{
  "name": "@mcp-b/react-webmcp",
  "version": "2.2.0",
  "description": "React hooks for Model Context Protocol (MCP) - expose React components as AI tools for Claude, ChatGPT, Cursor, and Copilot with Zod validation",
  "keywords": [
    "ai",
    "ai-agents",
    "ai-assistant",
    "ai-integration",
    "ai-tools",
    "anthropic",
    "browser",
    "chatgpt",
    "claude",
    "copilot",
    "cursor",
    "gemini",
    "hooks",
    "llm",
    "mcp",
    "mcp-client",
    "mcp-server",
    "model-context-protocol",
    "navigator-modelcontext",
    "openai",
    "react",
    "react-ai",
    "react-hooks",
    "tool-registration",
    "typescript",
    "web-ai",
    "webmcp"
  ],
  "homepage": "https://docs.mcp-b.ai/packages/react-webmcp",
  "bugs": {
    "url": "https://github.com/WebMCP-org/npm-packages/issues"
  },
  "license": "MIT",
  "author": "WebMCP Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WebMCP-org/npm-packages.git",
    "directory": "packages/react-webmcp"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vp pack",
    "build:prod": "NODE_ENV=prod vp pack",
    "check": "vp check --fix",
    "clean": "rm -rf dist",
    "format": "vp fmt --write",
    "lint": "vp lint --fix",
    "prepublishOnly": "node ../../scripts/validate-publish.js && pnpm run build:prod",
    "publish:dry": "pnpm publish --access public --dry-run",
    "publish:npm": "pnpm publish --access public",
    "test": "vp test run",
    "test:watch": "vp test",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.strict-null-checks-false.json --noEmit && vp test run --typecheck --silent",
    "version:major": "pnpm version major --no-git-tag-version",
    "version:minor": "pnpm version minor --no-git-tag-version",
    "version:patch": "pnpm version patch --no-git-tag-version"
  },
  "dependencies": {
    "@mcp-b/global": "workspace:*",
    "@mcp-b/transports": "workspace:*",
    "@mcp-b/webmcp-polyfill": "workspace:*",
    "@mcp-b/webmcp-ts-sdk": "workspace:*",
    "@mcp-b/webmcp-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "playwright": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-react": "^2.0.4"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "zod": "^3.25 || ^4.0",
    "zod-to-json-schema": "^3.25.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "zod-to-json-schema": {
      "optional": true
    }
  }
}
