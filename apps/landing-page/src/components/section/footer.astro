---
import { siteConfig } from "@/lib/config";

const { links, name, parentName, parentUrl } = siteConfig;
const contactEmail = links.email;

const footerSections = [
  {
    title: "Software",
    links: [
      { label: "Documentation", href: "https://docs.mcp-b.ai" },
      {
        label: "Extension",
        href: "https://chromewebstore.google.com/detail/mcp-b-extension/daohopfhkdelnpemnhlekblhnikhdhfa",
      },
      { label: "npm packages", href: "https://www.npmjs.com/org/mcp-b" },
    ],
  },
  {
    title: "Company",
    links: [
      { label: "SigVelo", href: parentUrl },
      { label: "Blog", href: "https://sigvelo.com/blog" },
      { label: "Privacy", href: "/privacy" },
      { label: "Terms", href: "/terms" },
    ],
  },
];

const socialLinks = [
  {
    label: "GitHub",
    href: links.github,
    path: "M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z",
  },
  {
    label: "Twitter",
    href: links.twitter,
    path: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z",
  },
  {
    label: "Discord",
    href: links.discord,
    path: "M20.317 4.369A19.791 19.791 0 0 0 15.39 2.85a13.78 13.78 0 0 0-.632 1.307 18.43 18.43 0 0 0-5.518 0 13.038 13.038 0 0 0-.642-1.307 19.736 19.736 0 0 0-4.93 1.523C.55 9.003-.319 13.52.099 17.974a19.9 19.9 0 0 0 6.051 3.064 14.7 14.7 0 0 0 1.297-2.103 12.96 12.96 0 0 1-2.043-.978c.171-.126.338-.257.5-.39a14.27 14.27 0 0 0 12.19 0c.164.134.331.265.502.39a13.08 13.08 0 0 1-2.047.98 14.61 14.61 0 0 0 1.297 2.101 19.868 19.868 0 0 0 6.055-3.064c.5-5.164-.854-9.64-3.584-13.605ZM8.02 15.238c-1.18 0-2.157-1.084-2.157-2.419 0-1.334.957-2.418 2.157-2.418 1.21 0 2.177 1.095 2.157 2.418 0 1.335-.956 2.419-2.157 2.419Zm7.974 0c-1.18 0-2.157-1.084-2.157-2.419 0-1.334.957-2.418 2.157-2.418 1.21 0 2.177 1.095 2.157 2.418 0 1.335-.947 2.419-2.157 2.419Z",
  },
  {
    label: "LinkedIn",
    href: links.linkedin,
    path: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.036-1.849-3.036-1.851 0-2.134 1.445-2.134 2.939v5.666H9.356V9h3.414v1.561h.048c.476-.9 1.637-1.849 3.368-1.849 3.602 0 4.267 2.371 4.267 5.455v6.285ZM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124ZM7.114 20.452H3.558V9h3.556v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z",
  },
];
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <p class="footer-wordmark">{name}</p>
        <p class="footer-tagline">
          Open-source WebMCP tooling for websites and agents.
        </p>

        <form
          class="footer-contact"
          action={`mailto:${contactEmail}`}
          method="get"
          data-footer-contact
          data-contact-email={contactEmail}
        >
          <p class="footer-heading">
            Stay in touch / <a href={`mailto:${contactEmail}`}>{contactEmail}</a
            >
          </p>
          <div class="footer-contact-row">
            <label class="sr-only" for="footer-email">Your email</label>
            <input
              id="footer-email"
              type="email"
              placeholder="Your email..."
              autocomplete="email"
              required
            />
            <button
              type="button"
              aria-label="Email MCP-B"
              data-footer-contact-send
            >
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M4 12h15M13 6l6 6-6 6"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>
        </form>
      </div>

      {
        footerSections.map((section) => (
          <nav class="footer-nav" aria-label={`${section.title} links`}>
            <p class="footer-heading">{section.title}</p>
            <div class="footer-links">
              {section.links.map((link) => (
                <a
                  href={link.href}
                  target={link.href.startsWith("http") ? "_blank" : undefined}
                  rel={link.href.startsWith("http") ? "noreferrer" : undefined}
                >
                  {link.label}
                </a>
              ))}
            </div>
          </nav>
        ))
      }

      <nav class="footer-nav" aria-label="Stay in touch links">
        <p class="footer-heading">Stay in touch</p>
        <div class="footer-links footer-socials">
          {
            socialLinks.map((link) => (
              <a href={link.href} target="_blank" rel="noreferrer">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d={link.path} />
                </svg>
                <span>{link.label}</span>
              </a>
            ))
          }
        </div>
      </nav>
    </div>

    <div class="footer-legal">
      <span>&copy; {new Date().getFullYear()} {name}. All rights reserved.</span
      >
      <span>
        A <a href={parentUrl} target="_blank" rel="noreferrer">{parentName}</a> product.
      </span>
    </div>
  </div>
</footer>

<script is:inline>
  (() => {
    const form = document.querySelector("[data-footer-contact]");
    const sendButton = document.querySelector("[data-footer-contact-send]");
    if (
      !(form instanceof HTMLFormElement) ||
      !(sendButton instanceof HTMLButtonElement)
    )
      return;

    sendButton.addEventListener("click", () => {
      if (!form.reportValidity()) return;
      const emailInput = form.querySelector("input[type='email']");
      if (!(emailInput instanceof HTMLInputElement)) return;

      const email = emailInput.value.trim();
      const contactEmail = form.dataset.contactEmail;
      if (!contactEmail) return;
      const subject = "Stay in touch";
      const body = `Please keep me in the loop. You can reach me at ${email}.`;
      window.location.href = `mailto:${contactEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    });
  })();
</script>

<style>
  .site-footer {
    background: var(--sigvelo-public-blue);
    color: var(--sigvelo-public-on-blue, #fff);
    padding: clamp(3rem, 6vw, 5rem) clamp(1.5rem, 4vw, 3rem) 1.5rem;
  }

  .footer-inner {
    max-width: 88rem;
    margin-inline: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.1fr repeat(3, minmax(0, 0.9fr));
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }

  .footer-wordmark {
    margin: 0;
    color: #fff;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 0.9;
  }

  .footer-tagline {
    max-width: 30ch;
    margin: 1rem 0 0;
    color: rgb(255 255 255 / 0.82);
    font-size: 1.0625rem;
    line-height: 1.6;
  }

  .footer-heading {
    margin: 0 0 1rem;
    color: rgb(255 255 255 / 0.78);
    font-size: 1rem;
  }

  .footer-heading a,
  .footer-legal a {
    color: inherit;
    text-decoration: none;
  }

  .footer-heading a:hover,
  .footer-legal a:hover {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-links a {
    color: #fff;
    font-size: 1rem;
    text-decoration: none;
    transition: color 120ms ease;
  }

  .footer-links a:hover {
    color: rgb(255 255 255 / 0.78);
  }

  .footer-socials a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .footer-socials svg {
    width: 1.1rem;
    height: 1.1rem;
    flex: 0 0 auto;
  }

  .footer-contact {
    margin-top: 1.5rem;
  }

  .footer-contact-row {
    display: flex;
    border: 1px solid rgb(255 255 255 / 0.34);
  }

  .footer-contact input {
    min-width: 0;
    flex: 1;
    padding: 0.85rem 1rem;
    border: 0;
    background: transparent;
    color: #fff;
    font: inherit;
  }

  .footer-contact input::placeholder {
    color: rgb(255 255 255 / 0.72);
  }

  .footer-contact input:focus {
    outline: none;
  }

  .footer-contact button {
    padding-inline: 1.1rem;
    border: 0;
    border-left: 1px solid rgb(255 255 255 / 0.34);
    background: transparent;
    color: #fff;
    cursor: pointer;
  }

  .footer-links a:focus-visible,
  .footer-heading a:focus-visible,
  .footer-legal a:focus-visible,
  .footer-contact button:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
  }

  .footer-contact button:focus-visible {
    outline-offset: -3px;
  }

  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    margin-top: clamp(2.5rem, 5vw, 4rem);
    padding-top: 1.25rem;
    border-top: 1px solid rgb(255 255 255 / 0.34);
    color: rgb(255 255 255 / 0.78);
    font-size: 1rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 64rem) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 40rem) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-brand {
      grid-column: auto;
    }

    .footer-legal {
      flex-direction: column;
    }
  }
</style>
