    "validate": "mintlify validate"
  },
  "dependencies": {
    "@runtypelabs/persona-proxy": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "mintlify": "^4.2.415",
    "typescript": "catalog:",
    "wrangler": "^4.110.0"
  }
}
