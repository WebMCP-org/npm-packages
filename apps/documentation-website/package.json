{
  "name": "@mcp-b/documentation-website",
  "version": "1.0.0",
  "private": true,
  "description": "docs.mcp-b.ai documentation, powered by Mintlify",
  "scripts": {
    "build": "mintlify validate",
    "deploy:persona-proxy": "wrangler deploy --config wrangler.jsonc",
