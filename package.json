{
  "name": "@mcp-b/npm-packages",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "scripts": {
    "audit:ci:critical": "node ./scripts/audit-filtered.mjs --level critical --prod --ignore-prefix e2e__ --ignore-prefix examples__ --ignore-prefix 'packages__chrome-devtools-mcp>'",
    "audit:ci:high": "node ./scripts/audit-filtered.mjs --level high --prod --ignore-prefix e2e__ --ignore-prefix examples__ --ignore-prefix 'packages__chrome-devtools-mcp>'",
    "build": "pnpm -r --filter '!@mcp-b/example-*' --filter '!@mcp-b/chrome-devtools-mcp' --filter '!@mcp-b/landing-page' run build",
    "build:docs": "pnpm --filter @mcp-b/documentation-website build",
    "build:landing": "pnpm --filter @mcp-b/landing-page build",
    "changeset": "changeset",
    "changeset:publish": "pnpm build && changeset publish",
    "changeset:version": "changeset version",
    "check": "vp check --fix",
    "check:ci": "vp check",
    "check-all": "pnpm -r --filter '!@mcp-b/example-*' --filter '!@mcp-b/chrome-devtools-mcp' --filter '!@mcp-b/landing-page' run typecheck && vp check",
    "ci:publish": "pnpm publish -r --access public --no-git-checks",
    "clean": "git clean -xdf .cache .vite node_modules",
    "deploy:landing": "pnpm --filter @mcp-b/landing-page deploy",
    "dev:docs": "pnpm --filter @mcp-b/documentation-website dev",
    "dev:landing": "pnpm --filter @mcp-b/landing-page dev",
    "format": "vp fmt --write",
    "format:check": "vp fmt --check",
    "lint": "vp lint --fix",
    "lint:check": "vp lint",
    "prepare": "vp config",
    "preview:docs": "pnpm --filter @mcp-b/documentation-website preview",
    "preview:landing": "pnpm --filter @mcp-b/landing-page preview",
    "publish:all": "pnpm run build && pnpm publish -r --access public --no-git-checks",
    "publish:order": "echo 'Publish order: webmcp-types → webmcp-polyfill → webmcp-ts-sdk → transports → global → react-webmcp → chrome-devtools-mcp'",
    "syncpack:fix": "syncpack fix-mismatches",
    "syncpack:lint": "syncpack lint",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:e2e": "pnpm --filter mcp-e2e-tests run test:runtime-contract && pnpm --filter @mcp-b/webmcp-local-relay test:e2e && pnpm --filter @mcp-b/extension-tools test:e2e",
    "test:e2e:debug": "pnpm --filter mcp-e2e-tests test:debug",
    "test:e2e:frameworks": "pnpm --filter mcp-e2e-tests run test:integration:frameworks",
    "test:e2e:headed": "pnpm --filter mcp-e2e-tests test:headed",
    "test:e2e:tarball:global": "node ./scripts/test-global-tarball-e2e.mjs",
    "test:e2e:ui": "pnpm --filter mcp-e2e-tests test:ui",
    "test:hooks": "pnpm --filter usewebmcp test && pnpm --filter @mcp-b/react-webmcp test",
    "test:hooks:coverage": "pnpm --filter usewebmcp test -- --coverage && pnpm --filter @mcp-b/react-webmcp test -- --coverage",
    "test:unit": "pnpm test:unit:packages && pnpm test:hooks",
    "test:unit:coverage": "pnpm test:unit:packages:coverage && pnpm test:hooks:coverage",
    "test:unit:packages": "pnpm -r --filter '!@mcp-b/example-*' --filter '!@mcp-b/chrome-devtools-mcp' --filter '!@mcp-b/landing-page' --filter '!mcp-e2e-tests' --filter '!mcp-tab-transport-test-app' --filter '!usewebmcp' --filter '!@mcp-b/react-webmcp' run test",
    "test:unit:packages:coverage": "pnpm -r --filter '!@mcp-b/example-*' --filter '!@mcp-b/chrome-devtools-mcp' --filter '!@mcp-b/landing-page' --filter '!mcp-e2e-tests' --filter '!mcp-tab-transport-test-app' --filter '!usewebmcp' --filter '!@mcp-b/react-webmcp' run test -- --coverage",
    "typecheck": "pnpm -r --filter '!@mcp-b/example-*' --filter '!@mcp-b/chrome-devtools-mcp' --filter '!@mcp-b/landing-page' --filter '!mcp-e2e-tests' --filter '!mcp-tab-transport-test-app' run typecheck",
    "validate:docs": "pnpm --filter @mcp-b/documentation-website validate",
    "validate:publish": "node ./scripts/validate-publish.js"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "tslib": "^2.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@typescript/native-preview": "7.0.0-dev.20260315.1",
    "jiti": "^2.6.1",
    "syncpack": "^13.0.0",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12",
    "pnpm": "^10"
  },
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "overrides": {
      "ajv@8": ">=8.18.0",
      "basic-ftp": ">=5.2.0",
      "diff": ">=8.0.3",
      "hono": ">=4.12.2",
      "js-yaml@3": "^3.14.2",
      "js-yaml@4": ">=4.1.1",
      "lodash": ">=4.17.23",
      "minimatch": ">=10.2.3",
      "rollup@4": ">=4.59.0",
      "svelte@5": ">=5.53.5",
      "tmp": ">=0.2.4"
    }
  }
}
